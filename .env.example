# Transkreebatoriya — пример конфигурации через переменные окружения.
# Скопируйте этот файл в .env и отредактируйте нужные значения.
# Все параметры имеют разумные дефолты — .env необязателен для запуска.

# ── Whisper ───────────────────────────────────────────────────────────────────
# Варианты: tiny | base | small | medium | large-v3
# Чем больше модель — тем точнее, но медленнее и требует больше RAM/VRAM.
WHISPER_MODEL_NAME=base

# Устройство вычислений: auto | cpu | cuda
# auto → CUDA если доступно, иначе CPU
WHISPER_DEVICE=auto

# ── ffmpeg ────────────────────────────────────────────────────────────────────
# Путь к ffmpeg. Если ffmpeg в PATH — менять не нужно.
FFMPEG_PATH=ffmpeg

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_API_URL=http://localhost:11434/api/generate

# Модель для постобработки транскрипции.
# Варианты (по убыванию качества / возрастанию скорости):
#   qwen3:4b      — качество ★★★★, скорость ★★   (по умолчанию)
#   qwen2.5:1.5b  — качество ★★★,  скорость ★★★★
#   llama3.2:1b   — качество ★★,   скорость ★★★★★
OLLAMA_MODEL=qwen3:4b

# Максимум символов в одном чанке постобработки
POSTPROCESS_CHUNK_CHARS=3000

# Сколько чанков обрабатывать параллельно.
# Увеличьте вместе с OLLAMA_NUM_PARALLEL в start.bat для ускорения.
POSTPROCESS_CONCURRENCY=2

# Таймаут одного запроса к Ollama в секундах (на один чанк).
# Увеличьте если Ollama работает медленно (тяжёлая модель, слабый CPU).
OLLAMA_TIMEOUT=1800

# ── Лимиты файлов ─────────────────────────────────────────────────────────────
# Максимальный размер загружаемого файла в ГБ
MAX_FILE_SIZE_GB=6

# ── Сервер ────────────────────────────────────────────────────────────────────
APP_HOST=localhost
APP_PORT=8001

# ── Hugging Face (опционально) ────────────────────────────────────────────────
# Токен для ускоренной загрузки моделей с Hugging Face Hub.
# Получить: huggingface.co → Settings → Access Tokens
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
